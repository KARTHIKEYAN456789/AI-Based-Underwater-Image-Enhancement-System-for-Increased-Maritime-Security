"""Train the U-Net enhancer on UIEB pairs. CPU-friendly defaults."""
import argparse
import time
from pathlib import Path

import torch
import torch.nn as nn
from torch.utils.data import DataLoader

from dataset import UIEBPairs
from model import UNetEnhancer

ROOT = Path(__file__).resolve().parent.parent
CKPT = ROOT / "checkpoints"


def psnr(a, b):
    mse = torch.mean((a - b) ** 2)
    return -10 * torch.log10(mse + 1e-10)


def main(args):
    torch.manual_seed(0)
    device = "cuda" if torch.cuda.is_available() else "cpu"
    train_ds = UIEBPairs("train", size=args.size)
    val_ds = UIEBPairs("val", size=args.size)
    print(f"device={device}  train={len(train_ds)}  val={len(val_ds)}")

    train_dl = DataLoader(train_ds, batch_size=args.batch, shuffle=True, num_workers=args.workers)
    val_dl = DataLoader(val_ds, batch_size=args.batch, num_workers=args.workers)

    model = UNetEnhancer(base=args.base).to(device)
    print(f"params: {sum(p.numel() for p in model.parameters())/1e6:.2f}M")
    opt = torch.optim.Adam(model.parameters(), lr=args.lr)
    sched = torch.optim.lr_scheduler.CosineAnnealingLR(opt, T_max=args.epochs)
    l1 = nn.L1Loss()

    CKPT.mkdir(exist_ok=True)
    best_psnr = 0.0

    for epoch in range(1, args.epochs + 1):
        model.train()
        t0, tot = time.time(), 0.0
        for i, (raw, ref) in enumerate(train_dl, 1):
            raw, ref = raw.to(device), ref.to(device)
            out = model(raw)
            loss = l1(out, ref)
            opt.zero_grad()
            loss.backward()
            opt.step()
            tot += loss.item()
            if i % 10 == 0:
                print(f"  epoch {epoch} [{i}/{len(train_dl)}] L1={tot/i:.4f}", flush=True)
        sched.step()

        model.eval()
        vp, vn = 0.0, 0
        with torch.no_grad():
            for raw, ref in val_dl:
                raw, ref = raw.to(device), ref.to(device)
                out = model(raw)
                for j in range(out.shape[0]):
                    vp += psnr(out[j], ref[j]).item()
                    vn += 1
        vp /= vn
        print(f"epoch {epoch}: train L1={tot/len(train_dl):.4f}  val PSNR={vp:.2f} dB  "
              f"({time.time()-t0:.0f}s)", flush=True)
        if vp > best_psnr:
            best_psnr = vp
            torch.save(model.state_dict(), CKPT / "best.pt")
            print(f"  saved new best (PSNR {vp:.2f})", flush=True)

    torch.save(model.state_dict(), CKPT / "last.pt")
    print(f"done. best val PSNR = {best_psnr:.2f} dB")


if __name__ == "__main__":
    p = argparse.ArgumentParser()
    p.add_argument("--epochs", type=int, default=15)
    p.add_argument("--batch", type=int, default=8)
    p.add_argument("--size", type=int, default=128)
    p.add_argument("--base", type=int, default=32)
    p.add_argument("--lr", type=float, default=2e-4)
    p.add_argument("--workers", type=int, default=2)
    main(p.parse_args())
